# Sentry source map upload auth token for LOCAL client builds
#
# Copy this file to `.env.sentry-build-plugin` (gitignored) and fill in your
# token. It is read by client/vite.config.ts to upload source maps when running
# a local build (e.g. `yarn build-front:dev`). In CI the token comes from the
# SENTRY_AUTH_TOKEN build secret instead, so this file is only for local use.
#
# Create a token at https://konsti.sentry.io/settings/auth-tokens/
# (Release:admin, Organization:Read)
SENTRY_AUTH_TOKEN=
