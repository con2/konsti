{
  "name": "konsti-client",
  "version": "0.0.1",
  "private": true,
  "description": "Konsti signup tool client",
  "author": {
    "name": "Arttu Hanska"
  },
  "main": "src/index.tsx",
  "type": "commonjs",
  "scripts": {
    "build:ci": "yarn clean && webpack-cli",
    "build:dev": "yarn clean && webpack-cli",
    "build:kube-dev": "yarn clean && webpack-cli",
    "build:prod": "yarn clean && webpack-cli",
    "build:staging": "yarn clean && webpack-cli",
    "bundle-analyzer": "webpack-cli --profile --json > stats.json && webpack-bundle-analyzer stats.json build -m server",
    "clean": "yarn run -T rimraf build",
    "eslint": "yarn run -T eslint --no-warn-ignored .",
    "start": "webpack serve",
    "stylelint": "stylelint \"./**/*.{tsx,ts}\"",
    "test": "yarn run -T vitest run",
    "test:coverage": "yarn run -T vitest run --coverage",
    "test:watch": "yarn run -T vitest watch",
    "type-check": "yarn run -T tsc --noEmit"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.0",
    "@reduxjs/toolkit": "2.11.2",
    "@sentry/react": "10.45.0",
    "browserslist": "4.28.1",
    "core-js": "3.49.0",
    "i18next": "25.10.4",
    "i18next-browser-languagedetector": "8.2.1",
    "linkify-react": "4.3.2",
    "linkifyjs": "4.3.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-i18next": "16.6.1",
    "react-redux": "9.2.0",
    "react-router": "7.13.1",
    "regenerator-runtime": "0.14.1",
    "styled-components": "6.3.12",
    "use-debounce": "10.1.0"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.1",
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/node": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@double-great/stylelint-a11y": "3.4.7",
    "@mdx-js/loader": "3.1.1",
    "@pmmmwh/react-refresh-webpack-plugin": "0.6.2",
    "@types/dotenv-webpack": "7.0.8",
    "@types/mdx": "2.0.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@welldone-software/why-did-you-render": "10.0.1",
    "babel-loader": "10.1.1",
    "babel-plugin-module-resolver": "5.0.3",
    "babel-plugin-styled-components": "2.1.4",
    "clean-webpack-plugin": "4.0.0",
    "compression-webpack-plugin": "12.0.0",
    "copy-webpack-plugin": "14.0.0",
    "dotenv-webpack": "9.0.0",
    "file-loader": "6.2.0",
    "html-webpack-plugin": "5.6.6",
    "jsdom": "29.0.1",
    "postcss": "8.5.8",
    "postcss-styled-syntax": "0.7.1",
    "postcss-syntax": "0.36.2",
    "raw-loader": "4.0.2",
    "react-refresh": "0.18.0",
    "stylelint": "17.5.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "webpack": "5.105.4",
    "webpack-bundle-analyzer": "5.2.0",
    "webpack-cli": "7.0.2",
    "webpack-dev-server": "5.2.3",
    "webpack-merge": "6.0.1"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
