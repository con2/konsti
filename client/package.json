{
  "name": "client",
  "version": "0.0.1",
  "private": true,
  "description": "Konsti signup tool client",
  "author": {
    "name": "Arttu Hanska"
  },
  "main": "src/index.tsx",
  "type": "module",
  "scripts": {
    "build:ci": "vite build --mode ci",
    "build:dev": "vite build --mode development",
    "build:kube-dev": "vite build --mode kube-dev",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "eslint": "yarn run -TB eslint --cache --no-warn-ignored .",
    "start": "vite --clearScreen false",
    "stylelint": "stylelint --cache \"./**/*.{tsx,ts}\"",
    "test": "yarn run -T vitest run",
    "test:coverage": "yarn run -T vitest run --coverage",
    "test:watch": "yarn run -T vitest watch",
    "type-check": "yarn run -T tsc --noEmit"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/free-regular-svg-icons": "6.7.2",
    "@fortawesome/free-solid-svg-icons": "6.7.2",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@reduxjs/toolkit": "2.12.0",
    "@sentry/react": "10.58.0",
    "browserslist": "4.28.2",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "linkify-react": "4.3.3",
    "linkifyjs": "4.3.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.79.0",
    "react-i18next": "17.0.8",
    "react-redux": "9.3.0",
    "react-router": "7.18.0",
    "styled-components": "6.4.2",
    "use-debounce": "10.1.1"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.3",
    "@double-great/stylelint-a11y": "3.4.15",
    "@mdx-js/rollup": "3.1.1",
    "@types/mdx": "2.0.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@welldone-software/why-did-you-render": "10.0.1",
    "browserslist-to-esbuild": "2.1.1",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "postcss-styled-syntax": "0.7.1",
    "postcss-syntax": "0.36.2",
    "stylelint": "17.13.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "vite": "8.0.16",
    "vite-plugin-compression2": "2.5.3",
    "vite-plugin-static-copy": "4.1.1",
    "vite-plugin-svgr": "5.2.0"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
