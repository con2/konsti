{
  "name": "konsti-client",
  "version": "0.0.1",
  "private": true,
  "description": "Konsti signup tool client",
  "author": {
    "name": "Arttu Hanska"
  },
  "main": "src/index.tsx",
  "type": "commonjs",
  "scripts": {
    "build:ci": "vite build --mode ci",
    "build:dev": "vite build --mode development",
    "build:kube-dev": "vite build --mode kube-dev",
    "build:prod": "vite build --mode production",
    "build:staging": "vite build --mode staging",
    "eslint": "yarn run -T eslint --no-warn-ignored .",
    "start": "vite --clearScreen false",
    "stylelint": "stylelint \"./**/*.{tsx,ts}\"",
    "test": "yarn run -T vitest run",
    "test:coverage": "yarn run -T vitest run --coverage",
    "test:watch": "yarn run -T vitest watch",
    "type-check": "yarn run -T tsc --noEmit"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/free-regular-svg-icons": "7.2.0",
    "@fortawesome/free-solid-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.0",
    "@reduxjs/toolkit": "2.11.2",
    "@sentry/react": "10.47.0",
    "browserslist": "4.28.2",
    "i18next": "26.0.3",
    "i18next-browser-languagedetector": "8.2.1",
    "linkify-react": "4.3.2",
    "linkifyjs": "4.3.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.0",
    "react-i18next": "17.0.2",
    "react-redux": "9.2.0",
    "react-router": "7.13.2",
    "styled-components": "6.3.12",
    "use-debounce": "10.1.1"
  },
  "devDependencies": {
    "@axe-core/react": "4.11.1",
    "@double-great/stylelint-a11y": "3.4.9",
    "@mdx-js/rollup": "3.1.1",
    "@types/mdx": "2.0.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "@welldone-software/why-did-you-render": "10.0.1",
    "jsdom": "29.0.1",
    "postcss": "8.5.8",
    "postcss-styled-syntax": "0.7.1",
    "postcss-syntax": "0.36.2",
    "rollup": "4.60.1",
    "stylelint": "17.6.0",
    "stylelint-config-standard": "40.0.0",
    "stylelint-no-unsupported-browser-features": "8.1.1",
    "vite": "7.3.1",
    "vite-plugin-compression2": "2.5.3",
    "vite-plugin-static-copy": "3.4.0",
    "vite-plugin-svgr": "4.5.0",
    "vite-tsconfig-paths": "5.1.4"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
