{
  "name": "konsti-server",
  "version": "0.0.1",
  "private": true,
  "description": "Konsti signup tool server",
  "author": {
    "name": "Arttu Hanska"
  },
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "eslint": "yarn run -T eslint --no-warn-ignored .",
    "fixer": "tsx src/features/statistics/dataFixer.ts --",
    "generate-data": "tsx src/test/test-data-generation/generateTestDataCli.ts",
    "initialize-db": "tsx src/utils/initializeDatabase.ts",
    "generate-serials": "tsx src/utils/generateSerials.ts",
    "lint": "yarn eslint && yarn prettier:check",
    "remove-invalid-games": "NODE_ENV=development tsx src/test/scripts/removeInvalidGames.ts",
    "build": "yarn run -T rimraf dist/server && ncc build src/index.ts -o dist/server",
    "start-ncc": "node dist/server/index.js",
    "start": "tsx src/index.ts",
    "start:dev": "NODE_ENV=development SETTINGS=development tsx watch --clear-screen=false -r dotenv/config src/index.ts dotenv_config_path=.env.development",
    "start:test": "NODE_ENV=development SETTINGS=development tsx watch --clear-screen=false -r dotenv/config src/index.ts dotenv_config_path=.env.test",
    "stats": "tsx src/features/statistics/statGenerator.ts --",
    "test": "yarn run -T vitest run",
    "test-assign": "NODE_ENV=development tsx src/test/scripts/testAssignment.ts",
    "test:coverage": "yarn run -T vitest run --coverage",
    "test:watch": "yarn run -T vitest watch",
    "type-check": "yarn run -T tsc --noEmit",
    "update-popularity": "NODE_ENV=development tsx src/test/scripts/testUpdateProgramItemPopularity.ts",
    "verify-results": "NODE_ENV=development tsx src/test/scripts/testVerifyResults.ts",
    "update-kompassi-data": "NODE_ENV=development tsx src/test/scripts/loadKompassiDataToDb.ts",
    "load-past-event-data": "NODE_ENV=development tsx src/test/scripts/loadPastEventDataToDb.ts",
    "update-kompassi-datadump": "NODE_ENV=development tsx src/test/scripts/updateKompassiDataDump.ts",
    "check-start-times": "NODE_ENV=development tsx src/test/scripts/checkStartTimes.ts",
    "docker:db": "tsx src/test/scripts/dockerDb.ts"
  },
  "dependencies": {
    "@faker-js/faker": "10.4.0",
    "@sentry/node": "10.47.0",
    "@vercel/ncc": "0.38.4",
    "bcryptjs": "3.0.3",
    "commander": "14.0.3",
    "croner": "10.0.1",
    "dotenv": "17.4.0",
    "eventassigner-js": "0.1.6",
    "eventassigner-random": "0.3.2",
    "express": "5.2.1",
    "express-static-gzip": "3.0.0",
    "fastest-levenshtein": "1.0.16",
    "fastq": "1.20.1",
    "form-data": "4.0.5",
    "generate-serial-number": "0.0.3",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "mongoose": "9.3.3",
    "mongoose-lean-getters": "2.3.1",
    "mongoose-lean-virtuals": "2.1.0",
    "morgan": "1.10.1",
    "nodemailer": "8.0.4",
    "tsx": "4.21.0",
    "winston": "3.19.0",
    "winston-transport-sentry-node": "3.0.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "25.5.0",
    "@types/nodemailer": "7.0.11",
    "@types/supertest": "7.2.0",
    "mongodb-memory-server": "11.0.1",
    "supertest": "7.2.2"
  },
  "engines": {
    "node": ">=24.14.1"
  }
}
