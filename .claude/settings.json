{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"console.log('Reminder: use yarn, not npm.')\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/prettier.ts"
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/eslint.ts",
            "timeout": 60,
            "statusMessage": "Running ESLint..."
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/typecheck.ts",
            "timeout": 120,
            "statusMessage": "Type-checking..."
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/knip.ts",
            "timeout": 120,
            "statusMessage": "Running knip..."
          }
        ]
      }
    ]
  }
}
