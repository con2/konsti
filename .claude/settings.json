{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"console.log('Reminder: use yarn, not npm.')\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/prettier.ts\""
          },
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/eslint.ts\"",
            "timeout": 60,
            "statusMessage": "Running ESLint..."
          },
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck.ts\"",
            "timeout": 120,
            "statusMessage": "Type-checking..."
          },
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/knip.ts\"",
            "timeout": 120,
            "statusMessage": "Running knip..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/prettier.ts\"",
            "timeout": 60,
            "statusMessage": "Running Prettier..."
          },
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/eslint.ts\"",
            "timeout": 60,
            "statusMessage": "Running ESLint..."
          },
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck.ts\"",
            "timeout": 120,
            "statusMessage": "Type-checking..."
          },
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/knip.ts\"",
            "timeout": 120,
            "statusMessage": "Running knip..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx \"$CLAUDE_PROJECT_DIR/.claude/hooks/claudeMd.ts\"",
            "timeout": 30,
            "statusMessage": "Checking CLAUDE.md docs..."
          }
        ]
      }
    ]
  }
}
