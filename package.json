{
  "name": "konsti-monorepo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "type": "module",
  "scripts": {
    "build-front:ci": "yarn workspace client build:ci && yarn copy-front",
    "build-front:dev": "yarn workspace client build:dev && yarn copy-front",
    "build-front:kube-dev": "yarn workspace client build:kube-dev && yarn copy-front",
    "build-front:prod": "yarn workspace client build:prod && yarn copy-front",
    "build-front:staging": "yarn workspace client build:staging && yarn copy-front",
    "client": "yarn workspace client start",
    "copy-front": "rimraf server/front && ncp client/build server/front",
    "coverage": "rimraf coverage && npm-run-all --serial --continue-on-error coverage:vitest coverage:e2e coverage:report",
    "coverage:vitest": "vitest run --coverage",
    "coverage:e2e": "yarn workspace server docker:db && node scripts/runE2eCoverage.ts",
    "coverage:report": "node scripts/mergeCoverageReport.ts",
    "playwright": "yarn workspace server docker:db && LOG_LEVEL=warn npm-run-all --parallel server:test client playwright:start",
    "playwright:start": "npx playwright install && npx playwright test --ui --config ./playwright/",
    "playwright:trace": "npx playwright show-trace trace.zip",
    "playwright:debug": "PWDEBUG=1 npx playwright test --config ./playwright/",
    "docker-compose:start": "APP_SETTINGS=dev docker buildx build . --file Dockerfile --build-arg env=dev --tag server --load && APP_SETTINGS=dev docker compose -f ./docker/docker-compose.yml up --detach --remove-orphans",
    "docker-compose:stop": "APP_SETTINGS=dev docker compose -f ./docker/docker-compose.yml down --remove-orphans",
    "docker-compose:test": "yarn docker:build-ci && yarn docker-compose:run-e2e",
    "docker-compose:run-e2e": "node playwright/runE2e.ts",
    "docker:build-ci": "APP_SETTINGS=ci docker buildx build . --file Dockerfile --build-arg env=ci --tag server --load",
    "docker:build-prod": "docker buildx build --build-arg env=prod -t konsti-prod --load .",
    "docker:build-staging": "docker buildx build --build-arg env=staging -t konsti-staging --load .",
    "docker:build-dev": "docker buildx build --build-arg env=dev -t konsti-dev --load .",
    "docker:start-dev-with-local-db": "yarn docker:build-dev && docker run -p 5000:5000 -d --env-file ./docker/docker-dev.env konsti-dev",
    "eslint-inspect-config": "eslint-config-inspector",
    "eslint-timings": "TIMING=1 yarn eslint",
    "eslint:client": "yarn workspace client eslint",
    "eslint:server": "yarn workspace server eslint",
    "eslint:root": "eslint --cache --no-warn-ignored shared playwright scripts .claude/hooks \"*.ts\"",
    "eslint": "npm-run-all --parallel --continue-on-error --aggregate-output eslint:client eslint:server eslint:root",
    "eslint:fix": "eslint --fix .",
    "find-unused-translation-keys": "yarn workspace server find-unused-translation-keys",
    "lint": "yarn eslint && yarn stylelint && yarn prettier:check && yarn knip && yarn find-unused-translation-keys",
    "populate-db:dummy": "yarn workspace server generate-data --clean --users --admin --programItems --lotterySignups --eventLog",
    "populate-db:kompassi": "yarn workspace server generate-data --clean && yarn workspace server update-kompassi-data && yarn workspace server generate-data --users --admin --lotterySignups --eventLog",
    "populate-db:event": "yarn workspace server generate-data --clean && yarn workspace server load-past-event-data && yarn workspace server generate-data --users --admin --lotterySignups --eventLog",
    "postinstall": "husky|| true",
    "prettier:check": "prettier --cache --check \"./**/*.{json,md,mdx,ts,tsx,yml}\"",
    "prettier:write": "prettier --cache --write \"./**/*.{json,md,mdx,ts,tsx,yml}\"",
    "server": "yarn workspace server start:dev",
    "server:test": "yarn workspace server start:test",
    "start:dev": "yarn workspace server docker:db && npm-run-all --parallel server client",
    "start:test": "yarn workspace server docker:db && npm-run-all --parallel server:test client",
    "start": "yarn workspace server start",
    "stylelint": "yarn workspace client stylelint",
    "test-assign": "yarn workspace server test-assign",
    "test:watch": "yarn vitest watch",
    "knip": "knip --cache",
    "test": "yarn vitest run",
    "type-check": "npm-run-all --parallel --continue-on-error --aggregate-output type-check:client type-check:server type-check:shared type-check:root",
    "type-check:client": "tsc -p client --noEmit",
    "type-check:server": "tsc -p server --noEmit",
    "type-check:shared": "tsc -p shared --noEmit",
    "type-check:root": "tsc -p tsconfig.json --noEmit",
    "update-yarn": "yarn set version stable"
  },
  "dependencies": {
    "@yarnpkg/types": "4.0.1",
    "dayjs": "1.11.21",
    "ncp": "2.0.0",
    "npm-run-all2": "9.0.2",
    "remeda": "2.39.0",
    "rimraf": "6.1.3",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/compat": "2.1.0",
    "@eslint/config-inspector": "3.0.4",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.0",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/istanbul-lib-coverage": "2.0.6",
    "@types/istanbul-lib-report": "3.0.3",
    "@types/istanbul-lib-source-maps": "4.0.4",
    "@types/istanbul-reports": "3.0.4",
    "@typescript-eslint/utils": "8.61.1",
    "@vitest/coverage-istanbul": "4.1.9",
    "@vitest/eslint-plugin": "1.6.20",
    "c8": "11.0.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-compat": "7.0.2",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.8.1",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-only-error": "1.0.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-hooks-addons": "0.5.1",
    "eslint-plugin-unicorn": "67.0.0",
    "globals": "17.6.0",
    "istanbul-lib-coverage": "3.2.2",
    "istanbul-lib-report": "3.0.1",
    "istanbul-lib-source-maps": "5.0.6",
    "istanbul-reports": "3.2.0",
    "jiti": "2.7.0",
    "knip": "6.17.1",
    "prettier": "3.8.4",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.18.0"
  },
  "packageManager": "yarn@4.17.0"
}
