{
  "compilerOptions": {
    "module": "preserve",
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "allowUnreachableCode": false,
    "noErrorTruncation": true,
    "target": "es2025",
    "lib": ["es2025", "dom"],
    "types": ["node"],
    "libReplacement": false,
    "paths": {
      "client/*": ["./client/src/*"],
      "server/*": ["./server/src/*"],
      "shared/*": ["./shared/*"],
      "playwright/*": ["./playwright/*"],
      "scripts/*": ["./scripts/*"]
    }
  },
  "include": [
    "*.ts",
    "playwright/**/*.ts",
    "scripts/**/*.ts",
    ".claude/hooks/**/*.ts"
  ]
}
