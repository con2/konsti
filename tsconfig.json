{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022", "dom"],
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowUnreachableCode": false,
    "noErrorTruncation": true,
    "types": ["node", "mdx"],
    "libReplacement": false,
    "paths": {
      "client/*": ["./client/src/*"],
      "server/*": ["./server/src/*"],
      "shared/*": ["./shared/*"],
      "playwright/*": ["./playwright/*"]
    }
  }
}
