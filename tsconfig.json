{
  "compilerOptions": {
    "module": "preserve",
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "allowUnreachableCode": false,
    "noErrorTruncation": true,
    "types": [],
    "libReplacement": false,
    "paths": {
      "client/*": ["./client/src/*"],
      "server/*": ["./server/src/*"],
      "shared/*": ["./shared/*"],
      "playwright/*": ["./playwright/*"]
    }
  }
}
